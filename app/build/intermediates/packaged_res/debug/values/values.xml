<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent_blue">#2979FF</color>
    <color name="accent_red">#FF4444</color>
    <color name="accent_teal">#00BFA5</color>
    <color name="accent_yellow">#FFD600</color>
    <color name="bg_card">#1A1A2E</color>
    <color name="bg_dark">#0D0D1A</color>
    <color name="cell_bg">#1E1E3A</color>
    <color name="cell_filled">#2A2A4A</color>
    <color name="cell_frozen">#0D2A3A</color>
    <color name="white">#FFFFFF</color>
    <string name="app_name">XO Powers</string>
    <style name="PowerDialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorPrimary">@color/accent_yellow</item>
        <item name="android:background">@color/bg_card</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="Theme.XOPowers" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_yellow</item>
        <item name="colorPrimaryDark">@color/bg_dark</item>
        <item name="colorAccent">@color/accent_red</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>
</resources>