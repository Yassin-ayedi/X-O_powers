<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="12dp">

    <!-- Top Bar: Round + Score -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnQuit"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="← Menu"
            android:textSize="12sp"
            android:backgroundTint="#333333"
            android:textColor="#AAAAAA"/>

        <TextView
            android:id="@+id/tvRound"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Round 1 / 3"
            android:textColor="@color/accent_yellow"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="X: 0  |  O: 0"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Current Player Banner -->
    <TextView
        android:id="@+id/tvCurrentPlayer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚔ Player X's Turn"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/accent_red"
        android:gravity="center"
        android:padding="8dp"
        android:background="@drawable/player_banner_bg"
        android:layout_marginBottom="10dp"/>

    <!-- 4x4 Board Grid -->
    <GridLayout
        android:id="@+id/boardGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:columnCount="4"
        android:rowCount="4"
        android:layout_marginBottom="10dp"/>

    <!-- Power Info Text -->
    <TextView
        android:id="@+id/tvPowerInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎴 Pick a power, then tap the board!"
        android:textColor="#CCCCCC"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="6dp"
        android:layout_marginBottom="8dp"/>

    <!-- 3 Power Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <Button
            android:id="@+id/btnPower0"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Power 0"
            android:textSize="12sp"
            android:textColor="@color/white"/>

        <Button
            android:id="@+id/btnPower1"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Power 1"
            android:textSize="12sp"
            android:textColor="@color/white"/>

        <Button
            android:id="@+id/btnPower2"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Power 2"
            android:textSize="12sp"
            android:textColor="@color/white"/>

    </LinearLayout>

</LinearLayout>
